# Openfort keys — get them from https://dashboard.openfort.io
VITE_OPENFORT_PUBLISHABLE_KEY=<openfort_publishable_key>
VITE_SHIELD_PUBLISHABLE_KEY=<shield_publishable_key>

# Optional: enables WalletConnect in the Openfort connect modal.
# https://cloud.reown.com
VITE_WALLET_CONNECT_PROJECT_ID=<walletconnect_project_id>
